__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.DS_Store
*.db
*.sqlite3

# dashboard (React/Vite) — added in a later part
node_modules/
# Keep dashboard/dist itself in git (via .gitkeep): pyproject.toml
# force-includes it into the wheel, and hatchling errors if the path is
# missing entirely. The general dist/ rule above would swallow it, so
# re-include the directory before ignoring its build output.
!dashboard/dist/
dashboard/dist/*
!dashboard/dist/.gitkeep
